# Mission Control — Environment Variables
# Copy this file to .env.local and fill in the values.
# These are used by the Next.js API routes to proxy requests to your OpenClaw gateway.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — Gateway Connection
# ─────────────────────────────────────────────────────────────────────────────

# The public URL of your OpenClaw gateway.
# Find this in your gateway config or run: openclaw gateway status
# Example: https://your-gateway.example.com
GATEWAY_URL=https://your-gateway.example.com

# Your gateway auth token.
# Find this in ~/.config/openclaw/config.toml under [gateway.auth]
# The token is shown as a string value in the auth config section.
GATEWAY_TOKEN=your-gateway-token-here

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — App URL (for redirects and CORS)
# ─────────────────────────────────────────────────────────────────────────────

# The public URL where Mission Control is hosted.
# On Vercel this is auto-set, but set it explicitly for local dev.
# Example (local dev): http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
